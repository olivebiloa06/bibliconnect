{% extends 'base.html.twig' %}
{% block title %}Catalogue — BiblioConnect{% endblock %}
{% block body %}
<div style="max-width:900px;margin:2rem auto;padding:0 1rem">
    <h1>Catalogue des livres</h1>

    <form method="get" style="display:flex;gap:8px;margin-bottom:2rem;flex-wrap:wrap">
        <input type="text" name="q" value="{{ query }}" placeholder="Titre ou auteur..."
               style="flex:1;padding:8px;border:1px solid #ccc;border-radius:4px">
        <select name="category" style="padding:8px;border:1px solid #ccc;border-radius:4px">
            <option value="">Toutes les catégories</option>
            {% for cat in categories %}
                <option value="{{ cat.id }}" {% if catId == cat.id %}selected{% endif %}>
                    {{ cat.nom }}
                </option>
            {% endfor %}
        </select>
        <button type="submit"
                style="padding:8px 16px;background:#333;color:#fff;border:none;border-radius:4px;cursor:pointer">
            Rechercher
        </button>
    </form>

    {% if books is empty %}
        <p>Aucun livre trouvé.</p>
    {% else %}
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1.5rem">
            {% for book in books %}
            <div style="border:1px solid #ddd;border-radius:8px;padding:1rem">
                {% if book.imageName %}
                    <img src="/uploads/books/{{ book.imageName }}"
                         style="width:100%;height:150px;object-fit:cover;border-radius:4px;margin-bottom:8px">
                {% else %}
                    <div style="width:100%;height:150px;background:#f0f0f0;border-radius:4px;margin-bottom:8px;display:flex;align-items:center;justify-content:center;color:#999">
                        Pas d'image
                    </div>
                {% endif %}
                <h3 style="font-size:14px;margin:0 0 4px">{{ book.titre }}</h3>
                <p style="font-size:12px;color:#666;margin:0 0 4px">{{ book.auteur }}</p>
                <p style="font-size:12px;color:#999;margin:0 0 8px">
                    {{ book.category ? book.category.nom : 'Sans catégorie' }}
                </p>
                <p style="font-size:12px;margin:0 0 8px">
                    Stock : <strong>{{ book.stock }}</strong>
                </p>
                <a href="{{ path('book_show', {id: book.id}) }}"
                   style="display:block;text-align:center;padding:6px;background:#333;color:#fff;border-radius:4px;text-decoration:none;font-size:13px">
                    Voir le livre
                </a>
            </div>
            {% endfor %}
        </div>
    {% endif %}

    <div style="margin-top:2rem">
        <a href="{{ path('app_home') }}" style="color:#333">← Accueil</a>
    </div>
</div>
{% endblock %}