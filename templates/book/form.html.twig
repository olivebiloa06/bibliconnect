{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block body %}
<div style="max-width:600px;margin:2rem auto;padding:0 1rem">
    <h1>{{ title }}</h1>

    {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

        <div style="margin-bottom:1rem">
            {{ form_label(form.titre) }}
            {{ form_widget(form.titre, {'attr': {
                'style': 'width:100%;padding:8px;border:1px solid #ccc;border-radius:4px;margin-top:4px'
            }}) }}
            {{ form_errors(form.titre) }}
        </div>

        <div style="margin-bottom:1rem">
            {{ form_label(form.auteur) }}
            {{ form_widget(form.auteur, {'attr': {
                'style': 'width:100%;padding:8px;border:1px solid #ccc;border-radius:4px;margin-top:4px'
            }}) }}
            {{ form_errors(form.auteur) }}
        </div>

        <div style="margin-bottom:1rem">
            {{ form_label(form.langue) }}
            {{ form_widget(form.langue, {'attr': {
                'style': 'width:100%;padding:8px;border:1px solid #ccc;border-radius:4px;margin-top:4px'
            }}) }}
        </div>

        <div style="margin-bottom:1rem">
            {{ form_label(form.stock) }}
            {{ form_widget(form.stock, {'attr': {
                'style': 'width:100%;padding:8px;border:1px solid #ccc;border-radius:4px;margin-top:4px'
            }}) }}
            {{ form_errors(form.stock) }}
        </div>

        <div style="margin-bottom:1rem">
            {{ form_label(form.category) }}
            {{ form_widget(form.category, {'attr': {
                'style': 'width:100%;padding:8px;border:1px solid #ccc;border-radius:4px;margin-top:4px'
            }}) }}
        </div>

        <div style="margin-bottom:1.5rem">
            {{ form_label(form.imageFile) }}
            {% if book is defined and book.imageName %}
                <div style="margin:8px 0">
                    <img src="/uploads/books/{{ book.imageName }}"
                         style="height:80px;border-radius:4px">
                    <p style="font-size:12px;color:#666">Image actuelle</p>
                </div>
            {% endif %}
            {{ form_widget(form.imageFile) }}
            {{ form_errors(form.imageFile) }}
        </div>

        <div style="display:flex;gap:12px;align-items:center">
            <button type="submit"
                    style="padding:10px 24px;background:#333;color:#fff;border:none;border-radius:4px;cursor:pointer">
                Enregistrer
            </button>
            <a href="{{ path('book_index') }}" style="color:#666">Annuler</a>
        </div>

    {{ form_end(form) }}
</div>
{% endblock %}