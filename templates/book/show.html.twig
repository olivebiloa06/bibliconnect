{% extends 'base.html.twig' %}
{% block title %}{{ book.titre }}{% endblock %}
{% block body %}
<div style="max-width:800px;margin:2rem auto;padding:0 1rem">

    <a href="{{ path('book_index') }}" style="color:#333">← Retour au catalogue</a>

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div style="padding:10px;border-radius:4px;margin:1rem 0;
                background:{{ type == 'error' ? '#fee' : '#efe' }};
                color:{{ type == 'error' ? 'red' : 'green' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div style="display:flex;gap:2rem;margin-top:1.5rem;flex-wrap:wrap">
        <div>
            {% if book.imageName %}
                <img src="/uploads/books/{{ book.imageName }}"
                     style="width:180px;height:250px;object-fit:cover;border-radius:8px">
            {% else %}
                <div style="width:180px;height:250px;background:#f0f0f0;border-radius:8px;
                            display:flex;align-items:center;justify-content:center;color:#999">
                    Pas d'image
                </div>
            {% endif %}
        </div>

        <div style="flex:1;min-width:200px">
            <h1 style="margin:0 0 8px">{{ book.titre }}</h1>
            <p style="color:#666;margin:0 0 16px">{{ book.auteur }}</p>

            <table style="font-size:14px;border-collapse:collapse">
                <tr>
                    <td style="padding:4px 12px 4px 0;color:#666">Langue</td>
                    <td style="padding:4px 0">{{ book.langue ?? 'Non précisée' }}</td>
                </tr>
                <tr>
                    <td style="padding:4px 12px 4px 0;color:#666">Catégorie</td>
                    <td style="padding:4px 0">{{ book.category ? book.category.nom : 'Non précisée' }}</td>
                </tr>
                <tr>
                    <td style="padding:4px 12px 4px 0;color:#666">Stock</td>
                    <td style="padding:4px 0">
                        <span style="color:{{ book.stock > 0 ? 'green' : 'red' }}">
                            {{ book.stock > 0 ? book.stock ~ ' disponible(s)' : 'Indisponible' }}
                        </span>
                    </td>
                </tr>
            </table>

            {% if is_granted('ROLE_USER') %}
            <div style="display:flex;gap:8px;margin-top:1.5rem;flex-wrap:wrap">
                {% if book.stock > 0 %}
                    <a href="{{ path('app_reservation', {id: book.id}) }}"
                       style="padding:10px 20px;background:#333;color:#fff;border-radius:4px;text-decoration:none">
                        Réserver
                    </a>
                {% else %}
                    <span style="padding:10px 20px;background:#ccc;color:#666;border-radius:4px">
                        Indisponible
                    </span>
                {% endif %}
                <a href="{{ path('app_favoris', {id: book.id}) }}"
                   style="padding:10px 20px;background:#f5a623;color:#fff;border-radius:4px;text-decoration:none">
                    ♥ Favoris
                </a>
            </div>
            {% else %}
            <p style="margin-top:1rem">
                <a href="{{ path('app_login') }}" style="color:#333">Connectez-vous</a> pour réserver ou mettre en favoris.
            </p>
            {% endif %}
        </div>
    </div>

    <hr style="margin:2rem 0">

    <h2>Commentaires ({{ book.commentaires|length }})</h2>

    {% set approuves = book.commentaires|filter(c => c.approved) %}
    {% if approuves|length == 0 %}
        <p style="color:#666">Aucun commentaire approuvé pour ce livre.</p>
    {% else %}
        {% for commentaire in approuves %}
        <div style="border:1px solid #ddd;border-radius:8px;padding:1rem;margin-bottom:1rem">
            <div style="margin-bottom:6px">
                {% for i in 1..5 %}
                    <span style="font-size:18px;color:{{ i <= commentaire.note ? '#f5a623' : '#ddd' }}">★</span>
                {% endfor %}
                <span style="font-size:12px;color:#999;margin-left:8px">{{ commentaire.note }}/5</span>
            </div>
            <p style="margin:0 0 8px">{{ commentaire.contenu }}</p>
            <small style="color:#999">
                Par {{ commentaire.user.nom ?? commentaire.user.email }}
            </small>
        </div>
        {% endfor %}
    {% endif %}

    {% if is_granted('ROLE_USER') %}
    <div style="background:#f9f9f9;border-radius:8px;padding:1.5rem;margin-top:1.5rem">
        <h3 style="margin-top:0">Laisser un commentaire</h3>
        <form method="post" action="{{ path('app_commentaire', {id: book.id}) }}">

            <div style="margin-bottom:1rem">
                <label style="display:block;margin-bottom:8px">Note</label>
                <div id="stars" style="font-size:32px;cursor:pointer">
                    {% for i in 1..5 %}
                        <span class="star" data-value="{{ i }}"
                              style="color:#ddd;transition:color 0.1s">★</span>
                    {% endfor %}
                </div>
                <input type="hidden" name="note" id="noteInput" value="5">
            </div>

            <div style="margin-bottom:1rem">
                <label>Commentaire</label><br>
                <textarea name="contenu" rows="4" required
                          style="width:100%;padding:8px;border:1px solid #ccc;border-radius:4px;margin-top:4px;box-sizing:border-box"></textarea>
            </div>

            <input type="hidden" name="_token" value="{{ csrf_token('commentaire') }}">
            <button type="submit"
                    style="padding:10px 24px;background:#333;color:#fff;border:none;border-radius:4px;cursor:pointer">
                Envoyer
            </button>
        </form>
    </div>

    <script>
    const stars = document.querySelectorAll('.star');
    const noteInput = document.getElementById('noteInput');
    let selected = 5;

    function highlight(val) {
        stars.forEach(s => {
            s.style.color = parseInt(s.dataset.value) <= val ? '#f5a623' : '#ddd';
        });
    }

    highlight(selected);

    stars.forEach(star => {
        star.addEventListener('mouseover', () => highlight(parseInt(star.dataset.value)));
        star.addEventListener('mouseout', () => highlight(selected));
        star.addEventListener('click', () => {
            selected = parseInt(star.dataset.value);
            noteInput.value = selected;
            highlight(selected);
        });
    });
    </script>
    {% endif %}

</div>
{% endblock %}