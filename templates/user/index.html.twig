{% extends 'base.html.twig' %}
{% block title %}Mon profil{% endblock %}
{% block body %}
<div style="max-width:800px;margin:2rem auto;padding:0 1rem">
    <h1>Bonjour {{ user.nom ?? user.email }}</h1>
    <p style="color:#666">{{ user.email }}</p>

    <div style="display:flex;gap:1rem;margin:1.5rem 0;flex-wrap:wrap">
        <a href="{{ path('book_index') }}"
           style="padding:10px 20px;background:#333;color:#fff;border-radius:4px;text-decoration:none">
            Voir le catalogue
        </a>
        <a href="{{ path('app_logout') }}"
           style="padding:10px 20px;background:#999;color:#fff;border-radius:4px;text-decoration:none">
            Se déconnecter
        </a>
    </div>

    <hr>

    <h2>Mes réservations</h2>
    {% if user.reservations is empty %}
        <p>Aucune réservation.</p>
    {% else %}
        <table style="width:100%;border-collapse:collapse">
            <thead>
                <tr style="background:#f5f5f5">
                    <th style="padding:8px;border:1px solid #ddd;text-align:left">Livre</th>
                    <th style="padding:8px;border:1px solid #ddd;text-align:left">Du</th>
                    <th style="padding:8px;border:1px solid #ddd;text-align:left">Au</th>
                    <th style="padding:8px;border:1px solid #ddd;text-align:left">Statut</th>
                </tr>
            </thead>
            <tbody>
            {% for resa in user.reservations %}
                <tr>
                    <td style="padding:8px;border:1px solid #ddd">{{ resa.book.titre }}</td>
                    <td style="padding:8px;border:1px solid #ddd">{{ resa.dateDebut|date('d/m/Y') }}</td>
                    <td style="padding:8px;border:1px solid #ddd">{{ resa.dateFin|date('d/m/Y') }}</td>
                    <td style="padding:8px;border:1px solid #ddd">{{ resa.statut }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}

    <hr style="margin-top:2rem">

    <h2>Mes favoris</h2>
    {% if user.favoris is empty %}
        <p>Aucun favori.</p>
    {% else %}
        <div style="display:flex;flex-wrap:wrap;gap:1rem">
        {% for fav in user.favoris %}
            <div style="border:1px solid #ddd;border-radius:8px;padding:1rem;width:180px">
                <p style="font-weight:500;margin:0 0 4px">{{ fav.book.titre }}</p>
                <p style="color:#666;font-size:13px;margin:0">{{ fav.book.auteur }}</p>
                <a href="{{ path('book_show', {id: fav.book.id}) }}"
                   style="display:block;margin-top:8px;font-size:13px;color:#333">Voir →</a>
            </div>
        {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}