{% extends 'base.html.twig' %}
{% block title %}Réserver — {{ book.titre }}{% endblock %}
{% block body %}
<div style="max-width:500px;margin:2rem auto;padding:0 1rem">
    <h1>Réserver un livre</h1>

    <div style="background:#f5f5f5;padding:1rem;border-radius:8px;margin-bottom:1.5rem">
        <h2 style="margin:0 0 8px">{{ book.titre }}</h2>
        <p style="margin:0;color:#666">{{ book.auteur }}</p>
        <p style="margin:4px 0 0">Stock disponible : <strong>{{ book.stock }}</strong></p>
    </div>

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div style="padding:10px;border-radius:4px;margin-bottom:1rem;
                background:{{ type == 'error' ? '#fee' : '#efe' }};
                color:{{ type == 'error' ? 'red' : 'green' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <form method="post">
        <div style="margin-bottom:1rem">
            <label>Date de début</label><br>
            <input type="date"
                   name="dateDebut"
                   min="{{ 'now'|date('Y-m-d') }}"
                   value="{{ 'now'|date('Y-m-d') }}"
                   required
                   style="width:100%;padding:8px;border:1px solid #ccc;border-radius:4px;margin-top:4px">
        </div>

        <div style="margin-bottom:1.5rem">
            <label>Date de fin</label><br>
            <input type="date"
                   name="dateFin"
                   min="{{ 'now'|date('Y-m-d') }}"
                   value="{{ ('+14 days')|date('Y-m-d') }}"
                   required
                   style="width:100%;padding:8px;border:1px solid #ccc;border-radius:4px;margin-top:4px">
        </div>

        <button type="submit"
                style="width:100%;padding:10px;background:#333;color:#fff;border:none;border-radius:4px;cursor:pointer">
            Confirmer la réservation
        </button>
    </form>

    <p style="margin-top:1rem;text-align:center">
        <a href="{{ path('book_show', {id: book.id}) }}" style="color:#666">← Retour au livre</a>
    </p>
</div>
{% endblock %}